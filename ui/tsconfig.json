{
  "extends": "./.svelte-kit/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    // Scope ambient types to the UI; without this the repo-root @types/bun leaks in and
    // collides with SvelteKit/Vite's import.meta globals.
    "types": []
  }
}
